rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 1. HELPER FUNKTIONEN (High-Performance SaaS Mandanten-Logik)
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSameCompany(resourceCompanyId) {
      return isAuthenticated() && 
             request.auth.token.companyId != null && 
             request.auth.token.companyId == resourceCompanyId;
    }

    function isSystemAdmin() {
      return isAuthenticated() && request.auth.token.email in ["cv1@gmx.ch", "carlo@vesciodesign.ch"];
    }

    // Rollen Helper
    function isCompanyOwner(resourceCompanyId) {
      return isSameCompany(resourceCompanyId) && 
             (request.auth.token.role == "owner" || request.auth.token.role == "Owner");
    }

    function isManagement(resourceCompanyId) {
      return isSameCompany(resourceCompanyId) && request.auth.token.role == "management";
    }

    function isEmployee(resourceCompanyId) {
      return isSameCompany(resourceCompanyId) && request.auth.token.role == "employee";
    }

    // ABAC Permissions (Reflecting permissions.ts)
    function canCreateProject(resourceCompanyId) {
      return isCompanyOwner(resourceCompanyId) || isManagement(resourceCompanyId) || isEmployee(resourceCompanyId);
    }
    function canDeleteProject(resourceCompanyId) {
      return isCompanyOwner(resourceCompanyId) || isManagement(resourceCompanyId);
    }
    function canManageUsers(resourceCompanyId) {
      return isCompanyOwner(resourceCompanyId) || isManagement(resourceCompanyId);
    }
    function canViewFinance(resourceCompanyId) {
      return isCompanyOwner(resourceCompanyId) || isManagement(resourceCompanyId);
    }

    function isVisibleAndInCompany(resourceData) {
      return isSameCompany(resourceData.companyId) && 
             (resourceData.visibility == 'public' || resourceData.visibility == 'company' || resourceData.ownerId == request.auth.uid);
    }

    // ===============================================================
    // 2. GLOBALE REGELN & PUBLIC ROUTES
    // ===============================================================

    match /systemConfig/{docId} {
      allow read: if true;
      allow write: if false; 
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
    }

    match /temp_receipts/{docId} {
      allow create: if true;
      allow read, delete: if isAuthenticated(); 
    }

    match /invites/{inviteId} {
      allow read: if true;
      allow update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }

    // ===============================================================
    // 3. CORE SAAS DATEN
    // ===============================================================
    
    match /auditLogs/{logId} {
      allow read: if isSystemAdmin() || isCompanyOwner(resource.data.companyId) || isManagement(resource.data.companyId);
      allow create: if isSystemAdmin() || (
        isSameCompany(request.resource.data.companyId) &&
        request.resource.data.userId == request.auth.uid
      );
      allow update, delete: if false; // Logs sind unveränderbar (Immutable)
    }

    match /companies/{companyId} {
      allow read: if isSystemAdmin() || isSameCompany(companyId);
      allow update: if isSystemAdmin() || isCompanyOwner(companyId);
      allow create, delete: if isSystemAdmin();
    }

    match /users/{userId} {
      allow read: if isSystemAdmin() || request.auth.uid == userId || isSameCompany(resource.data.companyId);
      allow update: if isSystemAdmin() || (
        (request.auth.uid == userId || isCompanyOwner(resource.data.companyId)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'companyId', 'plan', 'hasActiveSubscription', 'stripeCustomerId', 'subscriptionId', 'subscriptionStatus', 'trialEndsAt']) || isSystemAdmin() || (isCompanyOwner(resource.data.companyId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'updatedAt'])))
      );
      allow create: if isSystemAdmin();
      allow delete: if isSystemAdmin() || isCompanyOwner(resource.data.companyId);
    }

    // ===============================================================
    // 4. PROJEKT & MODUL DATEN
    // ===============================================================

    match /projects/{projectId} {
      allow read, update: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow delete: if isSystemAdmin() || canDeleteProject(resource.data.companyId);
      allow create: if isSystemAdmin() || canCreateProject(request.resource.data.companyId);
    }
    match /projectMembers/{memberId} {
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /companyUsers/{userId} {
      allow read: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow update: if isSystemAdmin() || (
        isSameCompany(resource.data.companyId) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || canManageUsers(resource.data.companyId))
      );
      allow delete: if isSystemAdmin() || canManageUsers(resource.data.companyId);
      allow create: if isSystemAdmin() || (isSameCompany(request.resource.data.companyId) && canManageUsers(request.resource.data.companyId));
    }
    
    match /financeData/{docId} { 
      allow read, update: if isSystemAdmin() || canViewFinance(resource.data.companyId);
      allow delete: if isSystemAdmin() || isCompanyOwner(resource.data.companyId);
      allow create: if isSystemAdmin() || canViewFinance(request.resource.data.companyId); 
    }
    
    match /timeEntries/{entryId} {
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /defects/{defectId} {
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /cad_plans/{planId} {
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /documents/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /transactions/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /projectTasks/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /calendarEvents/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /audioNotes/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /whiteboardExports/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /chatMessages/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /goals/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId); 
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /siteData/{docId} {
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /projectSchedules/{docId} { 
      allow read, update: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow delete: if isSystemAdmin() || isCompanyOwner(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /videoCalls/{docId} { 
      allow read, update: if docId.matches('^meet-.*') || isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
      
      match /{subcollection}/{subDoc} {
        allow read, write: if docId.matches('^meet-.*') || isSystemAdmin() || isSameCompany(get(/databases/$(database)/documents/videoCalls/$(docId)).data.companyId);
      }
    }
    match /notifications/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /knowledgeDocs/{docId} { 
      allow read, update: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow delete: if isSystemAdmin() || isCompanyOwner(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /embeddings/{docId} { 
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId); 
    }
    match /slides/{docId} {
      allow read, update, delete: if isSystemAdmin() || isVisibleAndInCompany(resource.data);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /apiKeys/{docId} {
      allow read, update, delete: if isSystemAdmin() || isSameCompany(resource.data.companyId);
      allow create: if isSystemAdmin() || isSameCompany(request.resource.data.companyId);
    }
    match /companySettings/{docId} {
      allow read: if isSystemAdmin() || isSameCompany(docId);
      allow write: if isSystemAdmin() || isCompanyOwner(docId);
    }

    // ===============================================================
    // 5. CATCH-ALL FÜR UNBEKANNTE DOKUMENTE
    // ===============================================================
    match /{document=**} {
      allow read, write: if isSystemAdmin();
    }
  }
}