rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email in ["cv1@gmx.ch", "carlo@vesciodesign.ch"];
    }

    // 1. Profilbilder & Avatare
    match /avatars/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isSuperAdmin() || request.auth.uid == userId);
    }
    match /crm_avatars/{imageId} {
      allow read, write: if request.auth != null;
    }

    // 2. Öffentliche Scanner & Mobile Uploads (Ohne Login nutzbar via Session-ID)
    // Dateigröße auf max 10MB beschränkt um Spam zu verhindern
    match /temp_receipts/{imageId} { 
      allow create: if request.resource.size < 10 * 1024 * 1024;
      allow get: if true;
      allow list: if false;
      allow delete: if request.auth != null;
    }
    match /temp_mobile_uploads/{imageId} { 
      allow create: if request.resource.size < 10 * 1024 * 1024;
      allow get: if true;
      allow list: if false;
      allow delete: if request.auth != null;
    }
    match /scanned_vcards/{imageId} { 
      allow create: if request.resource.size < 5 * 1024 * 1024;
      allow get: if true;
      allow list: if false;
      allow delete: if request.auth != null;
    }

    // 3. System-Assets (AGBs, Logos etc.)
    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 4. Hochsichere Firmen-Tresore (Multi-Tenancy)
    // Dateinamen sind in Firebase Storage kryptografisch, daher reicht hier der Read-Check auf die Ordner-Ebene
    match /{companyId}/{allPaths=**} {
      allow read, write: if request.auth != null && (isSuperAdmin() || request.auth.token.companyId == companyId || companyId == 'demo-company');
    }

    // 5. Strenge Fallback-Sperre (Blockiert alles, was oben nicht explizit erlaubt wurde)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
