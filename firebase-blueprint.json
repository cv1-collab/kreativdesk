{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Kreativ-Desk OS",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Internal", "External Planner", "Client"] },
        "department": { "type": "string" },
        "hourlyRate": { "type": "number" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A project managed within the OS",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "client": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "on-hold"] },
        "budget": { "type": "number" },
        "spent": { "type": "number" },
        "dueDate": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "status", "ownerId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction related to a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Completed", "Pending", "Failed"] },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "projectId", "date", "description", "amount", "status", "ownerId"]
    },
    "Event": {
      "title": "Event",
      "description": "A calendar event or task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "title", "date", "ownerId"]
    },
    "Defect": {
      "title": "Defect",
      "description": "A construction or design defect",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved"] },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "assignee": { "type": "string" },
        "dueDate": { "type": "string" },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "title", "status", "priority", "ownerId"]
    },
    "WhiteboardElement": {
      "title": "WhiteboardElement",
      "description": "An element on the collaborative whiteboard",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["rectangle", "circle", "text", "line"] },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "color": { "type": "string" },
        "text": { "type": "string" },
        "ownerId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "type", "x", "y", "ownerId"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in the project chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "number" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "text", "senderId", "timestamp", "projectId"]
    },
    "AudioNote": {
      "title": "AudioNote",
      "description": "A recorded voice note with AI transcription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "string" },
        "aiSummary": { "type": "string" },
        "transcription": { "type": "string" },
        "audioData": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "title", "ownerId"]
    },
    "Template": {
      "title": "Template",
      "description": "A business template document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "lastUpdated": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["id", "name", "url", "type", "size", "lastUpdated", "ownerId"]
    },
    "DailyGoal": {
      "title": "DailyGoal",
      "description": "A daily goal for a project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "completed", "priority", "projectId", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Projects"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions"
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Calendar events"
    },
    "/defects/{defectId}": {
      "schema": { "$ref": "#/entities/Defect" },
      "description": "Defects"
    },
    "/whiteboardElements/{elementId}": {
      "schema": { "$ref": "#/entities/WhiteboardElement" },
      "description": "Whiteboard elements"
    },
    "/chatMessages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Chat messages"
    },
    "/audioNotes/{noteId}": {
      "schema": { "$ref": "#/entities/AudioNote" },
      "description": "Audio notes with transcription"
    },
    "/templates/{templateId}": {
      "schema": { "$ref": "#/entities/Template" },
      "description": "Business templates"
    },
    "/dailyGoals/{goalId}": {
      "schema": { "$ref": "#/entities/DailyGoal" },
      "description": "Daily goals for projects"
    }
  }
}
